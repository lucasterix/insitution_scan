APP_ENV=development
SECRET_KEY=change-me-in-production
DATABASE_URL=postgresql+asyncpg://scan:scan@postgres:5432/scan
REDIS_URL=redis://redis:6379/0
PUBLIC_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# Optional third-party API keys. Scanners skip silently if these stay empty.
